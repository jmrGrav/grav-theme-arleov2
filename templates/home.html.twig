{% extends 'partials/base.html.twig' %}

{% set active_lang = grav.language.getActive ?: grav.config.site.default_lang %}

{% block header %}
<header class="site-header">
    <div class="header-sidebar-zone">
        <a href="{{ home_url }}" class="header-logo">
            <img src="{{ url('theme://images/logo/583245d5-09b6-4cd3-bfff-789b97e4dda5.png') }}" alt="{{ site.title }}" />
        </a>
        <div class="header-search">
            <input type="search" id="header-search"
                   placeholder="{{ active_lang == 'en' ? 'Search…' : 'Rechercher…' }}"
                   autocomplete="off" />
        </div>
    </div>
    <div class="header-spacer"></div>
    <div class="header-controls">
        <a href="https://github.com/jmrGrav"
           target="_blank"
           rel="noopener noreferrer"
           class="header-icon-btn"
           title="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24"
                 width="18" height="18"
                 fill="currentColor"
                 aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23.735 1.035 2.805.795 3.48.225.075-.6.298-1.005.54-1.23-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
        </a>

        <button class="theme-toggle" id="theme-toggle" title="Changer le thème">🌙</button>
        <button class="sidebar-toggle" id="sidebar-toggle-btn" aria-label="Toggle menu">☰</button>
    </div>
</header>
{% endblock %}

{% block body %}
<section id="body-wrapper" class="section">
    <section class="container {{ grid_size }}">
        {% if page.header.display_title %}
        <div class="home-title-block">
            <span class="home-display-title">{{ page.header.display_title }}</span>
            {% if page.header.subtitle %}
                <span class="home-subtitle">{{ page.header.subtitle }}</span>
            {% endif %}
        </div>
        {% endif %}
        {{ page.content|raw }}
    </section>
</section>
{% endblock %}
