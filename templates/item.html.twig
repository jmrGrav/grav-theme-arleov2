{% extends 'partials/base.html.twig' %}

{# ── Meta SEO ── #}
{% block head %}
    {{ parent() }}
    {% if page.header.metadata.keywords is defined %}
        <meta name="keywords" content="{{ page.header.metadata.keywords|e('html') }}">
    {% elseif page.taxonomy.tag %}
        <meta name="keywords" content="{{ page.taxonomy.tag|join(', ') }}">
    {% endif %}
    {% if page.header.metadata.description is defined %}
        <meta name="description" content="{{ page.header.metadata.description|e('html') }}">
    {% elseif page.summary %}
        <meta name="description" content="{{ page.summary|striptags|slice(0,160)|e('html') }}">
    {% endif %}
    {% if page.header.author %}
        <meta name="author" content="{{ page.header.author|e('html') }}">
    {% endif %}
{% endblock %}

{% set active_lang = grav.language.getActive ?: grav.config.site.default_lang %}

{% block header %}
<header class="site-header">
    <div class="header-sidebar-zone">
        <a href="{{ home_url }}" class="header-logo">
            <img src="{{ url('theme://images/logo/583245d5-09b6-4cd3-bfff-789b97e4dda5.png') }}" alt="{{ site.title }}" />
        </a>
        <div class="header-search">
            <input type="search" id="header-search"
                   placeholder="{{ active_lang == 'en' ? 'Search…' : 'Rechercher…' }}"
                   autocomplete="off" />
        </div>
    </div>
    <div class="header-spacer"></div>
    <div class="header-controls">
        <a href="https://github.com/jmrGrav"
           target="_blank"
           rel="noopener noreferrer"
           class="header-icon-btn"
           title="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24"
                 width="18" height="18"
                 fill="currentColor"
                 aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23.735 1.035 2.805.795 3.48.225.075-.6.298-1.005.54-1.23-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
        </a>

        <button class="theme-toggle" id="theme-toggle" title="Changer le thème">🌙</button>
        <button class="sidebar-toggle" id="sidebar-toggle-btn" aria-label="Toggle menu">☰</button>
    </div>
</header>
{% endblock %}

{% block body %}
<section id="body-wrapper" class="section">
    <section class="container {{ grid_size }}">

        <article class="article-item h-entry">

            <header class="article-header">
                <h1 class="article-title p-name">{{ page.title }}</h1>

                <div class="article-meta">
                    {%- set display_date = page.modified ?: page.date -%}
                    {% if display_date %}
                        <span class="article-date-modified">
                            {{ active_lang == 'en' ? 'Modified' : 'Modifié le' }}
                            <time class="dt-modified" datetime="{{ display_date|date('c') }}">
                                {{ display_date|date(system.pages.dateformat.short) }}
                            </time>
                        </span>
                    {% endif %}
                </div>

                {% if page.taxonomy.tag %}
                    <div class="article-tags">
                        {% for tag in page.taxonomy.tag %}
                            {%- set tag_slug = tag|lower|replace({'é': 'e', 'è': 'e', 'ê': 'e', 'à': 'a', 'â': 'a', 'ç': 'c', 'î': 'i', 'ï': 'i', 'ô': 'o', 'û': 'u', 'ù': 'u', 'ü': 'u'}) -%}
                            <a href="{{ base_url }}/tag/{{ tag_slug }}" class="tag-badge">{{ tag }}</a>
                        {% endfor %}
                    </div>
                {% endif %}

                <hr class="article-header-sep">
            </header>

            <div class="article-content e-content">
                {{ page.content|raw }}
            </div>

            {# ── Voir aussi ── #}
            {%- set see_also_title = (active_lang == 'en') ? 'See Also' : 'Voir aussi' -%}
            {% if page.header.see_also is defined and page.header.see_also|length > 0 %}
            <aside class="article-related">
                <h4>{{ see_also_title }}</h4>
                <ul>
                    {% for link in page.header.see_also %}
                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                    {% endfor %}
                </ul>
            </aside>
            {% else %}
                {% set current_tags = page.taxonomy.tag ?? [] %}
                {% if current_tags|length > 0 %}
                    {% set related_found = [] %}
                    {% for tag in current_tags %}
                        {% if related_found|length < 3 %}
                            {% set tagged = grav.taxonomy.findTaxonomy({'tag': [tag]}) %}
                            {% for rel_path, score in tagged %}
                                {% set rel_page = grav.pages.get(rel_path) %}
                                {% if rel_page and rel_page.published and rel_page.route != page.route %}
                                    {% set already = false %}
                                    {% for r in related_found %}{% if r.route == rel_page.route %}{% set already = true %}{% endif %}{% endfor %}
                                    {% if not already and related_found|length < 3 %}
                                        {% set related_found = related_found|merge([rel_page]) %}
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    {% endfor %}
                    {% if related_found|length > 0 %}
                    <aside class="article-related">
                        <h4>{{ see_also_title }}</h4>
                        <ul>
                            {% for rel in related_found %}
                                <li><a href="{{ rel.url }}">{{ rel.title }}</a></li>
                            {% endfor %}
                        </ul>
                    </aside>
                    {% endif %}
                {% endif %}
            {% endif %}

            <footer class="article-footer">
                <p class="article-signature">— jmr</p>
            </footer>

        </article>

        {% set prev_page = page.prevSibling %}
        {% set next_page = page.nextSibling %}
        {% if prev_page or next_page %}
        <nav class="article-prevnext">
            {% if prev_page %}
                <a class="btn prevnext-prev" href="{{ prev_page.url }}">
                    ← {{ active_lang == 'en' ? 'Previous' : 'Précédent' }} : {{ prev_page.header.menu ?? prev_page.title }}
                </a>
            {% endif %}
            {% if next_page %}
                <a class="btn prevnext-next" href="{{ next_page.url }}">
                    {{ active_lang == 'en' ? 'Next' : 'Suivant' }} : {{ next_page.header.menu ?? next_page.title }} →
                </a>
            {% endif %}
        </nav>
        {% endif %}

    </section>
</section>
{% endblock %}
