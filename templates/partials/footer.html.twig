<section id="footer" class="section">
    <section class="container {{ grid_size }}">
        <p class="footer-content">
            <span><a href="https://getgrav.org">Grav</a> was <i class="fa fa-code"></i> with <i class="fa fa-heart-o pulse"></i> by <a href="https://trilby.media">Trilby Media</a>. &copy; {{ "now"|date("Y") }} arleo.eu</span>
            <span class="footer-sep">|</span>
            <a href="{{ grav.uri.rootUrl(true) }}/{{ active_lang }}/privacy-policies">
                {% if active_lang == 'en' %}Privacy Policy{% else %}Politique de confidentialité{% endif %}
            </a>
            <span class="footer-sep">|</span>
            <a href="https://status.arleo.eu" target="_blank" id="status-link" title="État des services">
                <span class="status-dot"></span>
                <span class="status-text">Status</span>
            </a>
        </p>
    </section>
</section>
<div id="arleo-cookie-banner">
    <div class="arleo-cookie-inner">
        <p class="arleo-cookie-text">
            Ce site utilise des cookies fonctionnels uniquement (préférences de thème). Aucun cookie de tracking.
            <a href="{{ base_url }}/politique-de-confidentialite">En savoir plus</a>.
        </p>
        <button id="arleo-cookie-accept">OK</button>
    </div>
</div>
